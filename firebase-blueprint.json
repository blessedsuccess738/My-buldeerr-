{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "The user's email." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents a user's project.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The project ID." },
        "ownerUid": { "type": "string", "description": "The UID of the owner." },
        "name": { "type": "string", "description": "The project name." },
        "description": { "type": "string", "description": "The project description." },
        "code": { "type": "string", "description": "The project code." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the project was created." }
      },
      "required": ["id", "ownerUid", "name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects."
    }
  }
}
